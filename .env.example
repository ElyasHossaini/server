# Gmail: App Password (Google Account → Security → 2-Step Verification → App passwords).
EMAIL_USER=
EMAIL_PASS=

# Inbox that receives inquiries (leave empty to use EMAIL_USER).
MAIL_TO=

# Optional: comma-separated origins allowed to call this API.
# ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Optional: default 8787 (must match web/vite.config.ts proxy target)
# PORT=8787
